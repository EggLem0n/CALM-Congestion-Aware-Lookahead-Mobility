__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Keep the folder TREE on GitHub (data/, models/, reports/) via .gitkeep
# placeholders, but never upload the actual datasets / weights / run outputs.
/data/**
!/data/**/
!/data/**/.gitkeep
/models/**
!/models/**/
!/models/**/.gitkeep
/reports/**
!/reports/**/
!/reports/**/.gitkeep

# Never upload these regardless of folder
*.npz
*.zip
*.mp4
*.ckpt

# Third-party clone (OpenSTL has its own .git — see README for clone + patch)
OpenSTL/

# Training artifacts / logs
work_dirs/
lightning_logs/

# Claude Code / local assistant config
.claude/
CLAUDE.md
.mcp.json

.venv/
.env
.idea/
.vscode/
